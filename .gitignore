# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
/.pnpm-store
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example IS committed; real secrets are not
.env
.env*.local
.env.production
.env.staging

# uploaded images (per-restaurant; rebuilt on deploy, mounted as docker volume)
docker/uploads/*
!docker/uploads/.gitkeep

# local design mockups / archives (not part of the app)
/Restaurante/
/Restaurante.zip
/Shopify-Skill/
/.atl/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# testing artifacts
playwright-report/
test-results/

# docker
docker/backups/
