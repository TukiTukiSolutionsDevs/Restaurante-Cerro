# Database
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Session encryption key — 32+ random bytes as hex (openssl rand -hex 32)
SESSION_SECRET=

# QR token signing key — 32+ random bytes as hex (openssl rand -hex 32)
QR_SECRET=

# Kitchen device pairing PIN signing key — 32+ random bytes as hex (openssl rand -hex 32)
DEVICE_PIN_SECRET=

# Seed script — dev admin PIN (override in .env.local; default is 543210)
# SEED_ADMIN_PIN=543210

# Runtime
NODE_ENV=production
