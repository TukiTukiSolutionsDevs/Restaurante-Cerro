# =============================================================================
# RESTAURANTE CERRO — Plantilla de variables de entorno para producción
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.production.example .env.production
#   2. Completa TODOS los valores vacíos antes de iniciar los contenedores.
#   3. NUNCA hagas commit de .env.production (ya está en .gitignore).
#
# Generar secretos seguros (64 caracteres hex):
#   openssl rand -hex 32
#
# Rotar cada 90 días. Después de rotar SESSION_SECRET, todos los usuarios
# deberán iniciar sesión nuevamente (sus tokens quedarán inválidos).
# =============================================================================

POSTGRES_PASSWORD=

# 64 hex chars — genera con: openssl rand -hex 32
SESSION_SECRET=
QR_SECRET=
DEVICE_PIN_SECRET=

RUN_CRON=true
NODE_ENV=production
